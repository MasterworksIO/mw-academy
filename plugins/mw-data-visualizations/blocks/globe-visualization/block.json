{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "mw/globe-visualization",
    "version": "1.0.0",
    "title": "Globe Visualization",
    "category": "mw-data-visualizations",
    "icon": "admin-site-alt3",
    "description": "3D interactive globe showing global art market metrics by region, powered by Three.js.",
    "keywords": [ "globe", "3d", "three.js", "map", "global", "art market", "visualization" ],
    "textdomain": "mw-data-visualizations",
    "supports": {
        "html": false,
        "align": [ "wide", "full" ],
        "spacing": {
            "margin": true,
            "padding": true
        }
    },
    "attributes": {
        "metric": {
            "type": "string",
            "default": "auction-volume",
            "enum": [ "auction-volume", "price-growth", "collector-density" ]
        },
        "year": {
            "type": "number",
            "default": 2025
        },
        "autoRotate": {
            "type": "boolean",
            "default": true
        },
        "highlightRegions": {
            "type": "array",
            "default": [],
            "items": {
                "type": "string"
            }
        }
    },
    "editorScript": "file:./edit.js",
    "style": "file:../../assets/css/blocks.css"
}
