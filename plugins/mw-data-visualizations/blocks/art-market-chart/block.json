{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "mw/art-market-chart",
    "version": "1.0.0",
    "title": "Art Market Chart",
    "category": "mw-data-visualizations",
    "icon": "chart-line",
    "description": "Interactive D3.js chart displaying art market index performance, segment indices, and benchmark comparisons.",
    "keywords": [ "chart", "art", "market", "index", "d3", "visualization" ],
    "textdomain": "mw-data-visualizations",
    "supports": {
        "html": false,
        "align": [ "wide", "full" ],
        "spacing": {
            "margin": true,
            "padding": true
        }
    },
    "attributes": {
        "chartType": {
            "type": "string",
            "default": "line",
            "enum": [ "line", "bar", "area" ]
        },
        "dataSource": {
            "type": "string",
            "default": "art-market-index",
            "enum": [ "art-market-index", "segment-index", "custom" ]
        },
        "period": {
            "type": "string",
            "default": "5y",
            "enum": [ "1y", "3y", "5y", "10y", "all" ]
        },
        "segments": {
            "type": "array",
            "default": [],
            "items": {
                "type": "string"
            }
        },
        "showBenchmarks": {
            "type": "boolean",
            "default": false
        },
        "title": {
            "type": "string",
            "default": "Art Market Performance"
        },
        "height": {
            "type": "number",
            "default": 400
        },
        "colorScheme": {
            "type": "string",
            "default": "brand",
            "enum": [ "brand", "sequential", "diverging" ]
        }
    },
    "editorScript": "file:./edit.js",
    "style": "file:../../assets/css/blocks.css"
}
